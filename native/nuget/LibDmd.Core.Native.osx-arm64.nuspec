<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/01/nuspec.xsd">
  <metadata>
    <id>LibDmd.Core.Native.osx-arm64</id>
    <title>LibDmd.Core - Native binaries for osx-arm64</title>
    <version>__VERSION__</version>
    <description>This package complements LibDmd.Core and contains the native binaries (libserum, libzedmd) for osx-arm64.</description>
    <summary>Native binaries (libserum, libzedmd) for osx-arm64</summary>
    <projectUrl>https://github.com/freezy/dmd-extensions</projectUrl>
    <repository type="git" url="https://github.com/freezy/dmd-extensions" />
    <tags>dmd pinball serum zedmd native binaries osx-arm64</tags>
    <license type="file">LICENSE</license>
    <authors>freezy and contributors</authors>
    <owners>freezy and contributors</owners>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <dependencies>
      <group targetFramework="netstandard2.1" />
    </dependencies>
  </metadata>
  <files>
    <file src="targets\LibDmd.Core.Native.osx-arm64.targets" target="build\netstandard2.1" />
    <file src="runtimes\osx-arm64\native\*" target="runtimes\osx-arm64\native" />
    <file src="..\..\LICENSE" target="LICENSE" />
    <file src="_._" target="lib\netstandard2.1" />
  </files>
</package>